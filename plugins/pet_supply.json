{
  "intent": "pet_supply",
  "name": "宠物用品",
  "description": "搜索宠物用品门店和商品信息",
  "params": {
    "action": {
      "type": "single_select",
      "required": true,
      "prompt": "请选择操作",
      "options": ["find_store", "find_product"]
    },
    "location": {
      "type": "location",
      "required": true,
      "prompt": "请输入搜索位置",
      "condition": "action"
    },
    "pet_type": {
      "type": "single_select",
      "required": false,
      "prompt": "请选择宠物类型",
      "options": ["狗", "猫", "鱼", "鸟"],
      "condition": "action == 'find_product'"
    },
    "category": {
      "type": "single_select",
      "required": false,
      "prompt": "请选择商品分类",
      "options": ["食品", "玩具", "护理", "窝垫"],
      "condition": "action == 'find_product'"
    },
    "min_rating": {
      "type": "number",
      "required": false,
      "default": 0,
      "prompt": "最低评分 (0-5)",
      "condition": "action == 'find_store'"
    }
  },
  "node_types": {
    "Store": {
      "attributes": ["name", "address", "location", "rating", "opening_hours"]
    },
    "Product": {
      "attributes": ["name", "category", "pet_type", "price", "stock", "brand"]
    }
  },
  "relation_types": {
    "SELLS": {
      "from": "Store",
      "to": "Product",
      "description": "门店在售该商品"
    }
  },
  "event_types": {}
}
