{
  "intent": "locksmith",
  "name": "开锁服务",
  "description": "查找附近锁匠和获取报价",
  "params": {
    "action": {
      "type": "single_select",
      "required": true,
      "prompt": "请选择操作",
      "options": ["find_locksmith", "get_quote"]
    },
    "location": {
      "type": "location",
      "required": true,
      "prompt": "请输入您的位置"
    },
    "lock_type": {
      "type": "single_select",
      "required": true,
      "prompt": "请选择锁类型",
      "options": ["门锁", "车锁", "保险柜", "指纹锁", "卷帘门"]
    },
    "time_period": {
      "type": "single_select",
      "required": false,
      "default": "白天",
      "prompt": "请选择时间段",
      "options": ["白天", "夜间", "凌晨"],
      "condition": "action == 'get_quote'"
    }
  },
  "node_types": {
    "Locksmith": {
      "attributes": ["name", "phone", "location", "rating", "skills", "base_price", "service_hours"]
    },
    "District": {
      "attributes": ["name", "city", "surcharge"]
    }
  },
  "relation_types": {
    "COVERS": {
      "from": "Locksmith",
      "to": "District",
      "description": "锁匠覆盖该区域"
    }
  },
  "event_types": {}
}
