{
  "intent": "ride_hailing",
  "name": "打车服务",
  "description": "查找附近空闲车辆和预估费用",
  "params": {
    "action": {
      "type": "single_select",
      "required": true,
      "prompt": "请选择操作",
      "options": ["find_car", "estimate_fare"]
    },
    "pickup": {
      "type": "location",
      "required": true,
      "prompt": "请输入上车地点"
    },
    "dropoff": {
      "type": "location",
      "required": false,
      "prompt": "请输入下车地点",
      "condition": "action == 'estimate_fare'"
    },
    "car_type": {
      "type": "single_select",
      "required": false,
      "prompt": "请选择车型",
      "options": ["快车", "专车", "拼车", "豪华车"],
      "default": "快车"
    }
  },
  "node_types": {
    "Vehicle": {
      "attributes": ["plate", "type", "status", "location", "capacity"]
    },
    "Driver": {
      "attributes": ["name", "phone", "rating"]
    },
    "Station": {
      "attributes": ["name", "location", "vehicle_count"]
    }
  },
  "relation_types": {
    "DRIVEN_BY": {
      "from": "Vehicle",
      "to": "Driver",
      "description": "该司机驾驶此车"
    },
    "PARKED_AT": {
      "from": "Vehicle",
      "to": "Station",
      "description": "车辆停靠在此站点"
    }
  },
  "event_types": {}
}
